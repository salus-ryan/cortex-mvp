{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCL Control Record",
  "description": "Semantic Compression Language — a typed, parseable control record emitted by the Cortex policy model.",
  "type": "object",
  "required": ["anchor", "relation", "fields"],
  "properties": {
    "anchor": {
      "type": "string",
      "enum": ["@state", "@memory", "@budget", "@verify", "@tool", "@repair", "@halt"],
      "description": "Domain or subsystem being addressed."
    },
    "relation": {
      "type": "string",
      "description": "Operator connecting anchor to action or state transition."
    },
    "fields": {
      "type": "object",
      "description": "Typed key-value scope containing action parameters."
    },
    "raw": {
      "type": "string",
      "description": "Original raw SCL text before parsing."
    }
  },
  "allOf": [
    {
      "if": {"properties": {"anchor": {"const": "@state"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["update", "snapshot"]},
          "fields": {
            "properties": {
              "task_id": {"type": "string"},
              "phase": {"type": "string", "enum": ["init", "diagnose", "plan", "execute", "verify", "repair", "halt"]},
              "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
              "last_error": {"type": "string"},
              "failure": {"type": "string"},
              "suspect": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@memory"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["read", "write", "compress", "ignore"]},
          "fields": {
            "properties": {
              "query": {"type": "string"},
              "key": {"type": "string"},
              "value": {"type": "string"},
              "ttl": {"type": "string", "enum": ["session", "persistent", "ephemeral"]},
              "source": {"type": "string"},
              "target": {"type": "string"},
              "max_tokens": {"type": "integer", "minimum": 1},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@budget"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["spend", "check", "snapshot"]},
          "fields": {
            "properties": {
              "units": {"type": "integer", "minimum": 0},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@verify"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["run", "assert"]},
          "fields": {
            "properties": {
              "type": {"type": "string", "enum": ["schema", "unit_test", "policy", "lint", "git_diff"]},
              "target": {"type": "string"}
            },
            "required": ["type", "target"]
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@tool"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["call", "deny"]},
          "fields": {
            "properties": {
              "name": {"type": "string"},
              "args": {"type": "string"},
              "target": {"type": "string"},
              "strategy": {"type": "string"},
              "risk": {"type": "string", "enum": ["read_only", "write_limited", "verify", "memory", "deny", "halt"]},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@repair"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["rollback", "patch", "diagnose"]},
          "fields": {
            "properties": {
              "artifact": {"type": "string"},
              "reason": {"type": "string"},
              "target": {"type": "string"},
              "strategy": {"type": "string"}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"anchor": {"const": "@halt"}}},
      "then": {
        "properties": {
          "relation": {"enum": ["answer", "fail", "defer"]},
          "fields": {
            "properties": {
              "status": {"type": "string", "enum": ["complete", "blocked", "budget_exhausted", "insufficient_evidence", "failed"]},
              "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
              "evidence": {"type": "string"},
              "reason": {"type": "string"},
              "missing": {"type": "string"}
            },
            "required": ["status"]
          }
        }
      }
    }
  ]
}
